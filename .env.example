# =============================================================================
# AIOS Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to version control.
#
# Usage (Linux/macOS):
#   cp .env.example .env
#   export $(grep -v '^#' .env | xargs)
#   cd backend && ./gradlew bootRun
#
# Usage (Windows PowerShell):
#   Copy-Item .env.example .env
#   # Load variables manually or use a dotenv tool
# =============================================================================

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=local

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL (matches docker-compose.yml defaults for local) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_os
POSTGRES_USER=aios
POSTGRES_PASSWORD=aios_dev_password
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# --- AIOS API Authentication ---
# Header: X-API-Key (placeholder — replace with JWT in production)
AIOS_API_KEY=dev-api-key-change-me

# --- LiteLLM Proxy (OpenAI-compatible) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-local

# --- AI Model Configuration ---
AIOS_DEFAULT_MODEL=phi4
AIOS_FALLBACK_MODEL=qwen3
AIOS_CHAT_TEMPERATURE=0.7
AIOS_EMBEDDING_MODEL=nomic-embed-text
AIOS_EMBEDDING_DIMENSIONS=1536

# --- Memory / RAG ---
AIOS_MEMORY_RETRIEVAL_LIMIT=5
AIOS_MEMORY_MIN_TRUST=0.5
AIOS_SEMANTIC_CACHE_MAX=100
AIOS_SEMANTIC_CACHE_TTL=3600

# --- CORS (comma-separated origins for dev/prod profiles) ---
AIOS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Connection Pool (prod) ---
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5

# --- OAuth (planned — Phase 3+) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth2/callback/google

# --- Ollama (host-level, routed via LiteLLM — not read directly by AIOS) ---
# OLLAMA_HOST=http://localhost:11434
